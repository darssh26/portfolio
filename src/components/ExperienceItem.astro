---
import type { Experience } from "../data/experience";

interface Props {
  item: Experience;
  isLast: boolean;
}

const { item, isLast } = Astro.props;
---

<li class="exp-item reveal" class:list={{ last: isLast }}>
  {!isLast && <span class="rail" aria-hidden="true" />}
  <span class="dot" aria-hidden="true"></span>

  <div class="exp-card">
    <div class="exp-row">
      <h3 class="exp-role">
        {item.role}
        <span class="sep" aria-hidden="true">·</span>
        <span class="exp-company">{item.company}</span>
      </h3>
      <p class="exp-dates">{item.start} — {item.end}</p>
    </div>
    <p class="exp-loc">{item.location}</p>

    <ul class="exp-bullets">
      {
        item.bullets.map((b) => (
          <li>
            <span class="bullet-dot" aria-hidden="true" />
            <span>{b}</span>
          </li>
        ))
      }
    </ul>
  </div>
</li>

<style>
  .exp-item {
    position: relative;
    padding-left: 2.25rem;
    padding-bottom: 2.5rem;
  }
  .exp-item.last {
    padding-bottom: 0;
  }
  .rail {
    position: absolute;
    left: 7px;
    top: 1rem;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      color-mix(in oklch, var(--primary) 40%, transparent),
      var(--border) 60%
    );
  }
  .dot {
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: 2px solid var(--primary);
    background: var(--bg);
    box-shadow: 0 0 0 5px color-mix(in oklch, var(--primary) 12%, transparent);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .exp-item:hover .dot {
    box-shadow: 0 0 0 8px color-mix(in oklch, var(--primary) 16%, transparent);
    transform: scale(1.08);
  }
  .exp-card {
    padding: 0.25rem 0.25rem 0.25rem 0;
    border-radius: var(--radius-md);
    transition: transform 0.2s ease;
  }
  .exp-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
  }
  .exp-role {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .sep {
    color: var(--primary);
    margin: 0 0.25rem;
  }
  .exp-company {
    color: var(--text);
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .exp-dates {
    margin: 0;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in oklch, var(--surface) 70%, transparent);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-soft);
    white-space: nowrap;
  }
  .exp-loc {
    margin: 0.35rem 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  .exp-bullets {
    margin: 0.875rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .exp-bullets li {
    display: flex;
    gap: 0.7rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-soft);
  }
  .bullet-dot {
    flex: none;
    margin-top: 0.55rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: color-mix(in oklch, var(--primary) 70%, var(--text-muted));
  }
</style>
