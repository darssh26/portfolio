---
import type { SkillGroup } from "../data/skills";

interface Props {
  group: SkillGroup;
}

const { group } = Astro.props;
const isEmphasized = group.emphasis === true;
---

<div class="skill-card reveal" class:list={{ emphasized: isEmphasized }}>
  <h3 class="eyebrow">{group.heading}</h3>
  <ul class="skill-list">
    {group.items.map((item) => <li class="skill-pill">{item}</li>)}
  </ul>
</div>

<style>
  .skill-card {
    position: relative;
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: color-mix(in oklch, var(--surface) 80%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition:
      border-color 0.2s,
      transform 0.25s,
      box-shadow 0.25s;
  }
  .skill-card:hover {
    border-color: color-mix(in oklch, var(--primary) 30%, var(--border));
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .skill-card.emphasized {
    border-color: color-mix(in oklch, var(--primary) 40%, var(--border));
    background: linear-gradient(
      135deg,
      color-mix(in oklch, var(--primary) 8%, var(--bg)),
      color-mix(in oklch, var(--accent) 6%, var(--bg))
    );
  }
  .skill-card.emphasized::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      color-mix(in oklch, var(--primary) 50%, transparent),
      transparent 55%,
      color-mix(in oklch, var(--accent) 45%, transparent)
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  @media (min-width: 640px) {
    .skill-card.emphasized {
      grid-column: span 2;
    }
  }
  .skill-card .eyebrow {
    margin: 0 0 1rem;
  }
  .skill-card.emphasized .eyebrow {
    color: var(--primary);
  }
  .skill-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .skill-pill {
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-size: 0.8125rem;
    color: var(--text);
    transition:
      border-color 0.15s,
      color 0.15s,
      background-color 0.15s,
      transform 0.15s;
  }
  .skill-pill:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: translateY(-1px);
  }
  .skill-card.emphasized .skill-pill {
    background: color-mix(in oklch, var(--bg) 88%, transparent);
    border-color: color-mix(in oklch, var(--primary) 28%, var(--border));
    color: var(--text);
  }
</style>
