---
import SectionHeading from "./SectionHeading.astro";
import { education } from "../data/education";
---

<section
  id="education"
  aria-labelledby="education-heading"
  class="edu-section"
>
  <div class="mx-auto max-w-[1100px] scroll-mt-16 px-6 py-16 sm:px-10 sm:py-20">
    <SectionHeading
      id="education-heading"
      eyebrow="04 — Credentials"
      title="Education & certifications"
    />
    <ul class="edu-list mt-10">
      {
        education.map((item) => (
          <li class="reveal">
            <span class="dot" aria-hidden="true" />
            {item.url ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer">
                {item.title}
                <svg
                  class="ext"
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M7 17 17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </a>
            ) : (
              <span>{item.title}</span>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .edu-section {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .edu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .edu-list li {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in oklch, var(--bg) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    font-size: 0.95rem;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .edu-list li:hover {
    border-color: color-mix(in oklch, var(--primary) 30%, var(--border));
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }
  .dot {
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gradient-text);
    box-shadow: 0 0 0 4px color-mix(in oklch, var(--primary) 12%, transparent);
  }
  .edu-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
    text-decoration: none;
    text-underline-offset: 4px;
    transition: color 0.15s;
  }
  .edu-list a:hover {
    color: var(--primary);
  }
  .ext {
    opacity: 0.6;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .edu-list a:hover .ext {
    opacity: 1;
    transform: translate(2px, -2px);
  }
</style>
