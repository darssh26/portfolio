---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="proj-card reveal">
  <div class="proj-head">
    <h4 class="proj-name">{project.name}</h4>
    <span class="proj-arrow" aria-hidden="true">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 17 17 7"></path>
        <path d="M7 7h10v10"></path>
      </svg>
    </span>
  </div>
  <p class="proj-desc">{project.description}</p>
  {
    project.links.length > 0 && (
      <div class="proj-links">
        {project.links.map((link) =>
          link.url && link.url !== "#" ? (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="proj-chip"
            >
              {link.label}
            </a>
          ) : (
            <span class="proj-chip placeholder">{link.label}</span>
          )
        )}
      </div>
    )
  }
</article>

<style>
  .proj-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg);
    overflow: hidden;
    transition:
      border-color 0.2s,
      box-shadow 0.25s,
      transform 0.25s;
  }
  .proj-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: var(--gradient-text);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .proj-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      400px circle at var(--mx, 50%) var(--my, -20%),
      color-mix(in oklch, var(--primary) 12%, transparent),
      transparent 50%
    );
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .proj-card:hover {
    border-color: color-mix(in oklch, var(--primary) 35%, var(--border));
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .proj-card:hover::before,
  .proj-card:hover::after {
    opacity: 1;
  }

  .proj-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .proj-name {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .proj-arrow {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: color-mix(in oklch, var(--primary) 10%, transparent);
    color: var(--primary);
    transform: translate(2px, -2px);
    transition: transform 0.25s ease, background-color 0.2s ease;
  }
  .proj-card:hover .proj-arrow {
    transform: translate(0, 0);
    background: color-mix(in oklch, var(--primary) 18%, transparent);
  }
  .proj-desc {
    margin: 0.5rem 0 0;
    flex: 1;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-soft);
  }
  .proj-links {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .proj-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-soft);
    transition:
      border-color 0.15s,
      color 0.15s,
      background-color 0.15s;
  }
  a.proj-chip:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: color-mix(in oklch, var(--primary) 8%, transparent);
  }
  .proj-chip.placeholder {
    border-style: dashed;
    color: var(--text-muted);
    background: transparent;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".proj-card").forEach((card) => {
    card.addEventListener("pointermove", (e) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty("--mx", `${e.clientX - r.left}px`);
      card.style.setProperty("--my", `${e.clientY - r.top}px`);
    });
  });
</script>
