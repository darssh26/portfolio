---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="proj-card">
  <h4 class="proj-name">{project.name}</h4>
  <p class="proj-desc">{project.description}</p>
  {
    project.links.length > 0 && (
      <div class="proj-links">
        {project.links.map((link) =>
          link.url && link.url !== "#" ? (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="proj-chip"
            >
              {link.label}
            </a>
          ) : (
            <span class="proj-chip placeholder">{link.label}</span>
          )
        )}
      </div>
    )
  }
</article>

<style>
  .proj-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg);
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }
  .proj-card:hover {
    border-color: var(--primary);
    box-shadow: 0 1px 0 0 color-mix(in oklch, var(--primary) 8%, transparent);
  }
  .proj-name {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .proj-desc {
    margin: 0.375rem 0 0;
    flex: 1;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--text-soft);
  }
  .proj-links {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .proj-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-soft);
    transition:
      border-color 0.15s,
      color 0.15s;
  }
  a.proj-chip:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .proj-chip.placeholder {
    border-style: dashed;
    color: var(--text-muted);
  }
</style>
