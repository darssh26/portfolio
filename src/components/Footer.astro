---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div
    class="mx-auto flex max-w-[1100px] flex-col items-start justify-between gap-3 px-6 py-8 sm:flex-row sm:items-center sm:px-10"
  >
    <p class="mono">© {year} {site.name} · {site.tagline}</p>
    <div class="links">
      <a href={`mailto:${site.email}`} aria-label="Email">Email</a>
      <span aria-hidden="true">·</span>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <span aria-hidden="true">·</span>
      <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href="#" aria-label="Back to top">Top ↑</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: color-mix(in oklch, var(--bg) 92%, transparent);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }
  .links {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
  }
  .links a {
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .links a:hover {
    color: var(--primary);
  }
  .links span {
    opacity: 0.5;
  }
</style>
