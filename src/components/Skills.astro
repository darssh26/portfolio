---
import SectionHeading from "./SectionHeading.astro";
import SkillGroup from "./SkillGroup.astro";
import { skillGroups } from "../data/skills";
---

<section
  id="skills"
  aria-labelledby="skills-heading"
  class="mx-auto max-w-[1100px] scroll-mt-16 px-6 py-16 sm:px-10 sm:py-20"
>
  <SectionHeading
    id="skills-heading"
    eyebrow="03 — Skills"
    title="What I bring"
  />
  <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
    {skillGroups.map((g) => <SkillGroup group={g} />)}
  </div>
</section>
