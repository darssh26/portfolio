---
import { site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";
import Wordmark from "./Wordmark.astro";
import { withBase } from "../utils/url";

const cvHref = withBase(site.cvPath);
---

<header class="site-header">
  <div class="mx-auto flex max-w-[1100px] items-center justify-between px-6 py-4 sm:px-10">
    <a href="#" class="block" aria-label="Home">
      <Wordmark size="sm" />
    </a>
    <nav class="flex items-center gap-1 text-sm">
      <a href="#experience" class="nav-link">Work</a>
      <a href="#skills" class="nav-link">Skills</a>
      <a href={cvHref} class="nav-link">CV</a>
      <a href="#contact" class="nav-link">Contact</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<section
  class="mx-auto grid max-w-[1100px] gap-10 px-6 pt-16 pb-12 sm:gap-16 sm:px-10 sm:pt-24 sm:pb-20 lg:grid-cols-[minmax(0,1fr)_minmax(0,360px)]"
>
  <div>
    <h1 class="hero-title">
      Tech Lead — <em>mobile</em>, IoT &amp; cross-platform engineering.
    </h1>
    <p class="hero-sub">{site.lede}</p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a href="#experience" class="btn-primary">
        View work
        <span aria-hidden="true">→</span>
      </a>
      <a href={cvHref} class="btn-ghost">Read CV</a>
    </div>
  </div>

  <aside class="hero-meta">
    <dl>
      <div>
        <dt>Status</dt>
        <dd><span class="status-dot" aria-hidden="true"></span>{site.status}</dd>
      </div>
      <div>
        <dt>Based</dt>
        <dd>{site.location} · {site.timezone}</dd>
      </div>
      <div>
        <dt>Stack</dt>
        <dd>{site.stack.join(" · ")}</dd>
      </div>
      <div>
        <dt>Cert</dt>
        <dd>{site.certs[0]}</dd>
      </div>
      <div>
        <dt>Teams</dt>
        <dd>Led 5–11 engineers</dd>
      </div>
    </dl>
  </aside>
</section>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
  }
  .nav-link {
    display: none;
    border-radius: 6px;
    padding: 0.375rem 0.75rem;
    color: var(--text-soft);
    transition: color 0.15s;
  }
  .nav-link:hover {
    color: var(--text);
  }
  @media (min-width: 640px) {
    .nav-link {
      display: inline-block;
    }
  }
  .hero-title {
    font-size: clamp(2.25rem, 4.5vw + 1rem, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--text);
    max-width: 14ch;
    margin: 0;
  }
  .hero-title em {
    font-style: normal;
    color: var(--primary);
  }
  .hero-sub {
    margin-top: 1.25rem;
    font-size: 18px;
    line-height: 1.55;
    color: var(--text-soft);
    max-width: 50ch;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: var(--radius-md);
    background: var(--primary);
    color: var(--on-primary);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: background-color 0.15s;
  }
  .btn-primary:hover {
    background: var(--primary-hover);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-strong);
    font-size: 14px;
    font-weight: 500;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .btn-ghost:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .hero-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  @media (min-width: 1024px) {
    .hero-meta {
      border-left: 1px solid var(--border);
      padding-left: 1.5rem;
    }
  }
  .hero-meta dl {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }
  .hero-meta dl > div {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }
  .hero-meta dt {
    color: var(--text-muted);
  }
  .hero-meta dd {
    color: var(--text);
    margin: 0;
  }
</style>
